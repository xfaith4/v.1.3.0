<Window
    x:Class="GenesysConversationAnalysis.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Genesys Conversation Analysis"
    Height="800" Width="1280"
    MinHeight="600" MinWidth="900"
    Background="#1E1E2E"
    Foreground="#CDD6F4"
    FontFamily="Segoe UI" FontSize="13"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Colour palette -->
        <SolidColorBrush x:Key="BrushBase"      Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BrushSurface"   Color="#313244"/>
        <SolidColorBrush x:Key="BrushOverlay"   Color="#45475A"/>
        <SolidColorBrush x:Key="BrushText"      Color="#CDD6F4"/>
        <SolidColorBrush x:Key="BrushSubtext"   Color="#A6ADC8"/>
        <SolidColorBrush x:Key="BrushBlue"      Color="#89B4FA"/>
        <SolidColorBrush x:Key="BrushGreen"     Color="#A6E3A1"/>
        <SolidColorBrush x:Key="BrushYellow"    Color="#F9E2AF"/>
        <SolidColorBrush x:Key="BrushRed"       Color="#F38BA8"/>
        <SolidColorBrush x:Key="BrushTeal"      Color="#94E2D5"/>

        <!-- Base button style -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource BrushSurface}"/>
            <Setter Property="Foreground"   Value="{StaticResource BrushText}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BrushOverlay}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrushOverlay}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource BrushBlue}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushBase}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button (Run) -->
        <Style x:Key="BtnAccent" BasedOn="{StaticResource BtnBase}" TargetType="Button">
            <Setter Property="Background"  Value="#3B547A"/>
            <Setter Property="Foreground"  Value="{StaticResource BrushBlue}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        <!-- Danger button (Cancel) -->
        <Style x:Key="BtnDanger" BasedOn="{StaticResource BtnBase}" TargetType="Button">
            <Setter Property="Background"  Value="#5C2B2B"/>
            <Setter Property="Foreground"  Value="{StaticResource BrushRed}"/>
        </Style>

        <!-- TextBox base -->
        <Style x:Key="TxtBase" TargetType="TextBox">
            <Setter Property="Background"        Value="{StaticResource BrushSurface}"/>
            <Setter Property="Foreground"        Value="{StaticResource BrushText}"/>
            <Setter Property="BorderBrush"       Value="{StaticResource BrushOverlay}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="4,3"/>
            <Setter Property="CaretBrush"        Value="{StaticResource BrushBlue}"/>
            <Setter Property="SelectionBrush"    Value="{StaticResource BrushBlue}"/>
        </Style>

        <!-- ComboBox base -->
        <Style x:Key="CmbBase" TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource BrushSurface}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushText}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushOverlay}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="4,3"/>
        </Style>

        <!-- DatePicker base -->
        <Style TargetType="DatePicker">
            <Setter Property="Background"    Value="{StaticResource BrushSurface}"/>
            <Setter Property="Foreground"    Value="{StaticResource BrushText}"/>
            <Setter Property="BorderBrush"   Value="{StaticResource BrushOverlay}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- DataGrid base -->
        <Style x:Key="DgBase" TargetType="DataGrid">
            <Setter Property="Background"              Value="{StaticResource BrushBase}"/>
            <Setter Property="Foreground"              Value="{StaticResource BrushText}"/>
            <Setter Property="BorderBrush"             Value="{StaticResource BrushOverlay}"/>
            <Setter Property="BorderThickness"         Value="1"/>
            <Setter Property="GridLinesVisibility"     Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BrushSurface}"/>
            <Setter Property="RowBackground"           Value="{StaticResource BrushBase}"/>
            <Setter Property="AlternatingRowBackground" Value="#252535"/>
            <Setter Property="ColumnHeaderHeight"      Value="28"/>
            <Setter Property="RowHeight"               Value="24"/>
            <Setter Property="SelectionMode"           Value="Single"/>
            <Setter Property="SelectionUnit"           Value="FullRow"/>
            <Setter Property="IsReadOnly"              Value="True"/>
            <Setter Property="AutoGenerateColumns"     Value="False"/>
            <Setter Property="CanUserAddRows"          Value="False"/>
            <Setter Property="CanUserDeleteRows"       Value="False"/>
            <Setter Property="HeadersVisibility"       Value="Column"/>
        </Style>

        <!-- Section label -->
        <Style x:Key="LblSection" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource BrushSubtext}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,8,0,2"/>
        </Style>

        <!-- Status badge base -->
        <Style x:Key="BadgeBase" TargetType="Border">
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="6,2"/>
            <Setter Property="Background"      Value="{StaticResource BrushOverlay}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Body -->
            <RowDefinition Height="26"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ HEADER -->
        <Border Grid.Row="0"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushOverlay}"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#x2699;" FontSize="18" Foreground="{StaticResource BrushBlue}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Genesys Conversation Analysis"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushText}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Connection status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse x:Name="ElpConnStatus" Width="8" Height="8"
                             Fill="{StaticResource BrushRed}" Margin="0,0,6,0"/>
                    <TextBlock x:Name="LblConnectionStatus"
                               Text="Not connected"
                               Foreground="{StaticResource BrushSubtext}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Header buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Spacing="6">
                    <Button x:Name="BtnConnect"
                            Content="Connect"
                            Style="{StaticResource BtnAccent}"
                            Width="90"/>
                    <Button x:Name="BtnSettings"
                            Content="&#x2699; Settings"
                            Style="{StaticResource BtnBase}"
                            Width="90"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ BODY -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220" MaxWidth="360"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────────────── LEFT PANEL (Run Config) ── -->
            <Border Grid.Column="0"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushOverlay}"
                    BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8">
                    <StackPanel>

                        <!-- Date Range -->
                        <TextBlock Text="DATE RANGE" Style="{StaticResource LblSection}"/>
                        <TextBlock Text="Start date" Foreground="{StaticResource BrushSubtext}" FontSize="11" Margin="0,4,0,2"/>
                        <DatePicker x:Name="DtpStartDate" Height="28"/>
                        <TextBlock Text="End date" Foreground="{StaticResource BrushSubtext}" FontSize="11" Margin="0,6,0,2"/>
                        <DatePicker x:Name="DtpEndDate" Height="28"/>

                        <!-- Filters -->
                        <TextBlock Text="FILTERS" Style="{StaticResource LblSection}"/>
                        <TextBlock Text="Direction" Foreground="{StaticResource BrushSubtext}" FontSize="11" Margin="0,4,0,2"/>
                        <ComboBox x:Name="CmbDirection" Style="{StaticResource CmbBase}" Height="28">
                            <ComboBoxItem Content="(all)"       IsSelected="True"/>
                            <ComboBoxItem Content="inbound"/>
                            <ComboBoxItem Content="outbound"/>
                        </ComboBox>
                        <TextBlock Text="Media type" Foreground="{StaticResource BrushSubtext}" FontSize="11" Margin="0,6,0,2"/>
                        <ComboBox x:Name="CmbMediaType" Style="{StaticResource CmbBase}" Height="28">
                            <ComboBoxItem Content="(all)"  IsSelected="True"/>
                            <ComboBoxItem Content="voice"/>
                            <ComboBoxItem Content="chat"/>
                            <ComboBoxItem Content="email"/>
                            <ComboBoxItem Content="callback"/>
                        </ComboBox>
                        <TextBlock Text="Queue (contains)" Foreground="{StaticResource BrushSubtext}" FontSize="11" Margin="0,6,0,2"/>
                        <TextBox x:Name="TxtQueue" Style="{StaticResource TxtBase}" Height="28"/>

                        <!-- Preview page size -->
                        <TextBlock Text="PREVIEW" Style="{StaticResource LblSection}"/>
                        <TextBlock Text="Page size" Foreground="{StaticResource BrushSubtext}" FontSize="11" Margin="0,4,0,2"/>
                        <TextBox x:Name="TxtPreviewPageSize" Style="{StaticResource TxtBase}"
                                 Height="28" Text="25"/>

                        <!-- Run buttons -->
                        <TextBlock Text="EXTRACT" Style="{StaticResource LblSection}"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnPreviewRun" Grid.Column="0"
                                    Content="&#x25B6; Preview"
                                    Style="{StaticResource BtnBase}" Height="30"/>
                            <Button x:Name="BtnRun" Grid.Column="2"
                                    Content="&#x25B6;&#x25B6; Full Run"
                                    Style="{StaticResource BtnAccent}" Height="30"/>
                        </Grid>
                        <Button x:Name="BtnCancelRun"
                                Content="&#x25A0; Cancel"
                                Style="{StaticResource BtnDanger}"
                                Height="28" Margin="0,4,0,0"
                                IsEnabled="False"/>

                        <!-- Run progress -->
                        <TextBlock x:Name="TxtRunStatus"
                                   Text="Idle"
                                   Foreground="{StaticResource BrushSubtext}"
                                   FontSize="11" Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                        <ProgressBar x:Name="PrgRun"
                                     Height="6" Margin="0,4,0,0"
                                     Background="{StaticResource BrushOverlay}"
                                     Foreground="{StaticResource BrushBlue}"
                                     Minimum="0" Maximum="100" Value="0"/>
                        <TextBlock x:Name="TxtRunProgress"
                                   Text=""
                                   Foreground="{StaticResource BrushSubtext}"
                                   FontSize="10" Margin="0,2,0,0"
                                   TextWrapping="Wrap"/>

                        <!-- Recent runs -->
                        <TextBlock Text="RECENT RUNS" Style="{StaticResource LblSection}"/>
                        <ListBox x:Name="LstRecentRuns"
                                 Background="{StaticResource BrushBase}"
                                 Foreground="{StaticResource BrushText}"
                                 BorderBrush="{StaticResource BrushOverlay}"
                                 BorderThickness="1"
                                 Height="140"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 FontSize="11"/>
                        <Button x:Name="BtnOpenRun"
                                Content="Open Selected Run"
                                Style="{StaticResource BtnBase}"
                                Height="28" Margin="0,4,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource BrushOverlay}"/>

            <!-- ─────────────────────────────── RIGHT PANEL (Workspace) ── -->
            <TabControl x:Name="TabWorkspace" Grid.Column="2"
                        Background="{StaticResource BrushBase}"
                        BorderBrush="{StaticResource BrushOverlay}"
                        BorderThickness="0">

                <!-- ═══════════════════════ TAB: CONVERSATIONS ════════════ -->
                <TabItem Header="Conversations" Foreground="{StaticResource BrushText}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="TxtSearch" Grid.Column="0"
                                     Style="{StaticResource TxtBase}" Height="28"
                                     ToolTip="Search by conversation ID or queue"
                                     Margin="0,0,4,0"/>
                            <Button x:Name="BtnSearch" Grid.Column="1"
                                    Content="Search" Style="{StaticResource BtnBase}"
                                    Height="28" Width="64" Margin="0,0,8,0"/>
                            <ComboBox x:Name="CmbFilterDirection" Grid.Column="2"
                                      Style="{StaticResource CmbBase}" Height="28" Margin="0,0,4,0">
                                <ComboBoxItem Content="All directions" IsSelected="True"/>
                                <ComboBoxItem Content="inbound"/>
                                <ComboBoxItem Content="outbound"/>
                            </ComboBox>
                            <ComboBox x:Name="CmbFilterMedia" Grid.Column="3"
                                      Style="{StaticResource CmbBase}" Height="28" Margin="0,0,8,0">
                                <ComboBoxItem Content="All media" IsSelected="True"/>
                                <ComboBoxItem Content="voice"/>
                                <ComboBoxItem Content="chat"/>
                                <ComboBoxItem Content="email"/>
                            </ComboBox>
                            <Button x:Name="BtnExportPageCsv" Grid.Column="5"
                                    Content="Export Page CSV"
                                    Style="{StaticResource BtnBase}" Height="28" Margin="0,0,4,0"/>
                            <Button x:Name="BtnExportRunCsv" Grid.Column="6"
                                    Content="Export All CSV"
                                    Style="{StaticResource BtnBase}" Height="28"/>
                        </Grid>

                        <!-- Conversations DataGrid -->
                        <DataGrid x:Name="DgConversations" Grid.Row="1"
                                  Style="{StaticResource DgBase}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Conversation ID"   Binding="{Binding ConversationId}" Width="240"/>
                                <DataGridTextColumn Header="Direction"          Binding="{Binding Direction}"       Width="80"/>
                                <DataGridTextColumn Header="Media"              Binding="{Binding MediaType}"       Width="70"/>
                                <DataGridTextColumn Header="Queue"              Binding="{Binding Queue}"           Width="180"/>
                                <DataGridTextColumn Header="Duration (s)"       Binding="{Binding DurationSec}"     Width="80"/>
                                <DataGridTextColumn Header="Disconnect"         Binding="{Binding Disconnect}"      Width="100"/>
                                <DataGridCheckBoxColumn Header="Hold"           Binding="{Binding HasHold}"         Width="50"/>
                                <DataGridCheckBoxColumn Header="MOS"            Binding="{Binding HasMos}"          Width="50"/>
                                <DataGridTextColumn Header="Segments"           Binding="{Binding SegmentCount}"    Width="70"/>
                                <DataGridTextColumn Header="Participants"        Binding="{Binding ParticipantCount}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Paging bar -->
                        <Grid Grid.Row="2" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnPrevPage" Grid.Column="0"
                                    Content="&#x276E; Prev" Style="{StaticResource BtnBase}"
                                    Width="70" Height="26"/>
                            <TextBlock x:Name="TxtPageInfo" Grid.Column="1"
                                       Text="Page 0 of 0  |  0 records"
                                       Foreground="{StaticResource BrushSubtext}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button x:Name="BtnNextPage" Grid.Column="2"
                                    Content="Next &#x276F;" Style="{StaticResource BtnBase}"
                                    Width="70" Height="26"/>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ═══════════════════════ TAB: DRILLDOWN ═══════════════ -->
                <TabItem Header="Drilldown" Foreground="{StaticResource BrushText}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Selected conversation label -->
                        <Border Grid.Row="0" Background="{StaticResource BrushSurface}"
                                BorderBrush="{StaticResource BrushOverlay}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="8,4" Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Conversation: " Foreground="{StaticResource BrushSubtext}"/>
                                <TextBlock x:Name="LblSelectedConversation"
                                           Text="(none selected)"
                                           Foreground="{StaticResource BrushBlue}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- Drilldown sub-tabs -->
                        <TabControl x:Name="TabDrilldown" Grid.Row="1"
                                    Background="{StaticResource BrushBase}"
                                    BorderBrush="{StaticResource BrushOverlay}">

                            <!-- Summary -->
                            <TabItem Header="Summary" Foreground="{StaticResource BrushText}">
                                <Grid Margin="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Button x:Name="BtnGenerateReport" Grid.Row="0"
                                            Content="Generate Impact Report for Filtered View"
                                            Style="{StaticResource BtnAccent}"
                                            Height="28" Margin="0,0,0,6"/>
                                    <TextBox x:Name="TxtDrillSummary" Grid.Row="1"
                                             Style="{StaticResource TxtBase}"
                                             IsReadOnly="True" TextWrapping="NoWrap"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             FontFamily="Consolas" FontSize="12"/>
                                </Grid>
                            </TabItem>

                            <!-- Participants -->
                            <TabItem Header="Participants" Foreground="{StaticResource BrushText}">
                                <DataGrid x:Name="DgParticipants"
                                          Style="{StaticResource DgBase}" Margin="4">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Participant ID" Binding="{Binding participantId}" Width="240"/>
                                        <DataGridTextColumn Header="Name"           Binding="{Binding participantName}" Width="160"/>
                                        <DataGridTextColumn Header="Purpose"        Binding="{Binding purpose}"        Width="90"/>
                                        <DataGridTextColumn Header="User ID"        Binding="{Binding userId}"         Width="220"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>

                            <!-- Segments -->
                            <TabItem Header="Segments" Foreground="{StaticResource BrushText}">
                                <DataGrid x:Name="DgSegments"
                                          Style="{StaticResource DgBase}" Margin="4">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Participant"    Binding="{Binding Purpose}"       Width="90"/>
                                        <DataGridTextColumn Header="Type"           Binding="{Binding SegmentType}"   Width="90"/>
                                        <DataGridTextColumn Header="Start"          Binding="{Binding SegmentStart}"  Width="180"/>
                                        <DataGridTextColumn Header="End"            Binding="{Binding SegmentEnd}"    Width="180"/>
                                        <DataGridTextColumn Header="Duration (s)"   Binding="{Binding DurationSec}"   Width="90"/>
                                        <DataGridTextColumn Header="Queue"          Binding="{Binding QueueName}"     Width="160"/>
                                        <DataGridTextColumn Header="Disconnect"     Binding="{Binding DisconnectType}" Width="110"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>

                            <!-- Attributes -->
                            <TabItem Header="Attributes" Foreground="{StaticResource BrushText}">
                                <Grid Margin="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBox x:Name="TxtAttributeSearch"
                                             Style="{StaticResource TxtBase}"
                                             Height="28" Margin="0,0,0,6"
                                             ToolTip="Filter attributes"/>
                                    <DataGrid x:Name="DgAttributes" Grid.Row="1"
                                              Style="{StaticResource DgBase}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name"  Binding="{Binding Name}"  Width="200"/>
                                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!-- MOS / Quality -->
                            <TabItem Header="MOS / Quality" Foreground="{StaticResource BrushText}">
                                <TextBox x:Name="TxtMosQuality"
                                         Style="{StaticResource TxtBase}"
                                         IsReadOnly="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12"
                                         Margin="4"/>
                            </TabItem>

                            <!-- Raw JSON -->
                            <TabItem Header="Raw JSON" Foreground="{StaticResource BrushText}">
                                <Grid Margin="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                                HorizontalAlignment="Right" Margin="0,0,0,4">
                                        <!-- BtnExpandJson: exists per spec; no handler is bound (known nuance) -->
                                        <Button x:Name="BtnExpandJson"
                                                Content="&#x26F6; Expand"
                                                Style="{StaticResource BtnBase}"
                                                Height="26" Width="80"/>
                                    </StackPanel>
                                    <TextBox x:Name="TxtRawJson" Grid.Row="1"
                                             Style="{StaticResource TxtBase}"
                                             IsReadOnly="True"
                                             HorizontalScrollBarVisibility="Auto"
                                             VerticalScrollBarVisibility="Auto"
                                             FontFamily="Consolas" FontSize="11"
                                             TextWrapping="NoWrap"/>
                                </Grid>
                            </TabItem>

                        </TabControl>
                    </Grid>
                </TabItem>

                <!-- ═══════════════════════ TAB: RUN CONSOLE ════════════ -->
                <TabItem Header="Run Console" Foreground="{StaticResource BrushText}">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="140"/>
                        </Grid.RowDefinitions>

                        <!-- Console header -->
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Status: " Foreground="{StaticResource BrushSubtext}"/>
                                <Border Style="{StaticResource BadgeBase}">
                                    <TextBlock x:Name="TxtConsoleStatus"
                                               Text="Idle"
                                               Foreground="{StaticResource BrushYellow}"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                            <Button x:Name="BtnCopyDiagnostics" Grid.Column="1"
                                    Content="&#x1F4CB; Copy Diagnostics"
                                    Style="{StaticResource BtnBase}"
                                    Height="28" Width="150"/>
                        </Grid>

                        <!-- Event log -->
                        <DataGrid x:Name="DgRunEvents" Grid.Row="1"
                                  Style="{StaticResource DgBase}" Margin="0,0,0,6">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time"    Binding="{Binding timestamp}" Width="170"/>
                                <DataGridTextColumn Header="Level"   Binding="{Binding level}"     Width="70"/>
                                <DataGridTextColumn Header="Message" Binding="{Binding message}"   Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Diagnostics label -->
                        <TextBlock Grid.Row="2"
                                   Text="DIAGNOSTICS OUTPUT"
                                   Style="{StaticResource LblSection}"
                                   Margin="0,0,0,2"/>

                        <!-- Diagnostics text -->
                        <TextBox x:Name="TxtDiagnostics" Grid.Row="3"
                                 Style="{StaticResource TxtBase}"
                                 IsReadOnly="True"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="11"
                                 TextWrapping="NoWrap"/>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ FOOTER -->
        <StatusBar Grid.Row="2"
                   Background="{StaticResource BrushSurface}"
                   BorderBrush="{StaticResource BrushOverlay}"
                   BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatusMain"
                           Text="Ready"
                           Foreground="{StaticResource BrushSubtext}"
                           FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TxtStatusRight"
                           Text=""
                           Foreground="{StaticResource BrushSubtext}"
                           FontSize="11"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>
